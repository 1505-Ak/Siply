generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id @default(uuid())
  username      String  @unique
  email         String  @unique
  passwordHash  String
  displayName   String
  bio           String?
  avatarUrl     String?
  favoriteDrink String?

  // Stats (Denormalized to match Java backend logic)
  followersCount Int     @default(0)
  followingCount Int     @default(0)
  totalDrinks    Int     @default(0)
  totalCities    Int     @default(0)
  totalCountries Int     @default(0)
  avgRating      Decimal @default(0)

  // Relations
  drinks          Drink[]
  feedPosts       FeedPost[]
  refreshTokens   RefreshToken[]
  likes           Like[]
  comments        Comment[]
  achievements    UserAchievement[]
  loyaltyProgress UserLoyaltyProgress[]

  // Self-referential relations for Follow system
  followers Follow[] @relation("following")
  following Follow[] @relation("follower")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Drink {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  category String
  rating   Decimal  @db.Decimal(3, 2)
  price    Decimal? @db.Decimal(10, 2)
  notes    String?  @db.Text

  locationName    String?
  locationCity    String?
  locationCountry String?
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)

  imageUrl   String?
  tags       String[] // Prisma handles Postgres TEXT[] arrays natively
  isFavorite Boolean  @default(false)

  likesCount    Int @default(0)
  commentsCount Int @default(0)

  likes     Like[]
  comments  Comment[]
  feedPosts FeedPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drinks")
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  category  String
  address   String?
  city      String?
  country   String?
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  hasStudentDiscount Boolean @default(false)
  hasHappyHour       Boolean @default(false)
  isPartner          Boolean @default(false)
  imageUrl           String?

  loyaltyPrograms LoyaltyProgram[]
  userProgress    UserLoyaltyProgress[]
  discounts       Discount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("venues")
}

model LoyaltyProgram {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  programType         String // points | visitCard | subscription
  pointsPerVisit      Int?
  pointsPerDollar     Int?
  hasMultiplier       Boolean  @default(false)
  multiplierRate      Decimal? @db.Decimal(3, 2)
  hasSubscription     Boolean  @default(false)
  subscriptionDetails String?
  hasVisitCard        Boolean  @default(false)
  visitCardGoal       Int?

  @@map("loyalty_programs")
}

model UserLoyaltyProgress {
  id      String @id @default(uuid())
  userId  String
  venueId String
  user    User   @relation(fields: [userId], references: [id])
  venue   Venue  @relation(fields: [venueId], references: [id])

  pointsEarned Int       @default(0)
  visitCount   Int       @default(0)
  isFavorite   Boolean   @default(false)
  lastVisit    DateTime?

  @@unique([userId, venueId])
  @@map("user_loyalty_progress")
}

model Discount {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  title              String
  description        String?
  discountPercentage Int?
  discountAmount     Decimal?  @db.Decimal(10, 2)
  requiresStudentId  Boolean   @default(false)
  validUntil         DateTime?
  isActive           Boolean   @default(true)

  @@map("discounts")
}

model FeedPost {
  id      String @id @default(uuid())
  userId  String
  drinkId String
  user    User   @relation(fields: [userId], references: [id])
  drink   Drink  @relation(fields: [drinkId], references: [id])

  content       String?
  imageUrl      String?
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  isTagged      Boolean  @default(false)
  taggedUsers   String[] // Array of User IDs

  createdAt DateTime @default(now())

  @@map("feed_posts")
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id])
  following   User   @relation("following", fields: [followingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

model Like {
  id      String @id @default(uuid())
  userId  String
  drinkId String
  user    User   @relation(fields: [userId], references: [id])
  drink   Drink  @relation(fields: [drinkId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, drinkId])
  @@map("likes")
}

model Comment {
  id      String @id @default(uuid())
  userId  String
  drinkId String
  user    User   @relation(fields: [userId], references: [id])
  drink   Drink  @relation(fields: [drinkId], references: [id])

  content   String
  createdAt DateTime @default(now())

  @@map("comments")
}

model Achievement {
  id               String  @id @default(uuid())
  code             String  @unique
  name             String
  description      String?
  icon             String
  requirementType  String
  requirementValue Int

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now())
  progress   Int      @default(0)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
