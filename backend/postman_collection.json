{
  "info": {
    "name": "Siply API",
    "description": "Complete API collection for Siply backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"Test User\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Drinks",
      "item": [
        {
          "name": "Get Drinks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drinks?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["drinks"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Create Drink",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cappuccino\",\n  \"category\": \"Coffee\",\n  \"rating\": 4.5,\n  \"price\": 5.50,\n  \"notes\": \"Perfect foam!\",\n  \"locationName\": \"Starbucks\",\n  \"locationCity\": \"San Francisco\",\n  \"locationCountry\": \"USA\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/drinks",
              "host": ["{{baseUrl}}"],
              "path": ["drinks"]
            }
          }
        },
        {
          "name": "Get Trending Drinks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drinks/trending/all",
              "host": ["{{baseUrl}}"],
              "path": ["drinks", "trending", "all"]
            }
          }
        }
      ]
    },
    {
      "name": "Social",
      "item": [
        {
          "name": "Get Feed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/social/feed",
              "host": ["{{baseUrl}}"],
              "path": ["social", "feed"]
            }
          }
        },
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/social/follow/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["social", "follow", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Like Drink",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/social/likes/:drinkId",
              "host": ["{{baseUrl}}"],
              "path": ["social", "likes", ":drinkId"],
              "variable": [
                {
                  "key": "drinkId",
                  "value": "drink-id-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Venues",
      "item": [
        {
          "name": "Get Venues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/venues",
              "host": ["{{baseUrl}}"],
              "path": ["venues"]
            }
          }
        },
        {
          "name": "Get Nearby Venues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/venues/nearby/search?latitude=37.7749&longitude=-122.4194&radius=5",
              "host": ["{{baseUrl}}"],
              "path": ["venues", "nearby", "search"],
              "query": [
                {
                  "key": "latitude",
                  "value": "37.7749"
                },
                {
                  "key": "longitude",
                  "value": "-122.4194"
                },
                {
                  "key": "radius",
                  "value": "5"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}


